# Nhost Auth (existing)
NEXT_PUBLIC_NHOST_SUBDOMAIN=
NEXT_PUBLIC_NHOST_REGION=
NHOST_JWT_SECRET=

# Nhost Functions — unified backend (required for BFF proxy to admin routes)
# Cloud: https://<subdomain>.functions.<region>.nhost.run
# Local: https://local.functions.local.nhost.run
# Full HTTP reference: ../../dropiti-nhost/documentation/api-doc-v1.md
NEXT_PUBLIC_FUNCTIONS_URL=

# Optional: comma-separated platform landlord user UUIDs (also set on Functions runtime)
DROPITI_PLATFORM_LANDLORD_USER_IDS=

# Airwallex Elements (browser-safe) + webhook handler only
NEXT_PUBLIC_AIRWALLEX_ENV=demo
# AIRWALLEX_CLIENT_ID=
# AIRWALLEX_API_KEY=  # server-only: /api/webhooks/airwallex
