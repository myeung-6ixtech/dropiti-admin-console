# Nhost Auth (existing)
NEXT_PUBLIC_NHOST_SUBDOMAIN=
NEXT_PUBLIC_NHOST_REGION=
NHOST_JWT_SECRET=

# Nhost Functions — unified backend (required for BFF proxy to admin routes)
# Cloud: https://<subdomain>.functions.<region>.nhost.run
# Local: https://local.functions.local.nhost.run
# Full HTTP reference: ../../dropiti-nhost/documentation/api-doc-v1.md
NEXT_PUBLIC_FUNCTIONS_URL=

# Optional: nhost (10 MB proxy, no S3 CORS) | s3 (5 MB proxy + presign fallback)
# Must match Functions MEDIA_STORAGE_BACKEND / auto-detected backend. See documentation/media-upload.md
NEXT_PUBLIC_MEDIA_STORAGE_BACKEND=nhost

# Server-only — Nhost Storage direct upload (v2) + display proxy.
# Quote the value if it contains ; or % characters. Aliases: HASURA_ADMIN_SECRET, NHOST_ADMIN_SECRET.
# HASURA_GRAPHQL_ADMIN_SECRET="your-hasura-admin-secret"

# Target Nhost Storage bucket for uploads. Must match MEDIA_STORAGE_BUCKET on the Nhost Functions.
# Defaults to "default" if unset. Set to your actual bucket name (e.g. dropiti-bucket).
# NHOST_STORAGE_BUCKET=default

# Optional: public web app origin (no trailing slash) for claim links when Functions status omits invitationUrl.
# Example: https://app.dropiti.com or http://localhost:3001 — path is always /transfer-ownership/<tokenUuid>
# NEXT_PUBLIC_DROPITI_CLIENT_ORIGIN=

# Optional: comma-separated platform landlord user UUIDs (also set on Functions runtime)
DROPITI_PLATFORM_LANDLORD_USER_IDS=

# Airwallex Elements (browser-safe) + webhook handler only
NEXT_PUBLIC_AIRWALLEX_ENV=demo
# AIRWALLEX_CLIENT_ID=
# AIRWALLEX_API_KEY=  # server-only: /api/webhooks/airwallex
